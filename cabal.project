packages: glean-hs.cabal

-- Allow newer base versions
allow-newer: base

-- NOTE: You must create cabal.project.local before building.
-- Run this once in the project root:
--
--   echo "package glean-hs" > cabal.project.local
--   echo "  extra-lib-dirs: $(pwd)/target/release" >> cabal.project.local
--
-- cabal.project.local is gitignored and sets the path to
-- the Rust library on your specific machine.
